---
export const prerender = true;
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION, TORC_APP_URL } from "../consts";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import FormattedDate from "@/components/FormattedDate.astro";
import barca from "../images/torc.webp";
import timer from "../images/timer.webp";
import friends from "../images/friends.webp";

const posts = (await getCollection("blog")).sort(
  (a, b) => (b.data.pubDate || 0).valueOf() - (a.data.pubDate || 0).valueOf()
);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="landing-body">
    <Header />

    <main class="landing-main">

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- HERO                                                       -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="hero">
        <div class="hero-glow"></div>
        <div class="container showcase-centered">
          <h1 class="hero-headline hero-fade-in">
            A run club for everyone.
          </h1>
          <div class="hero-ctas hero-fade-in delay-1">
            <a href={`${TORC_APP_URL}/login`} class="btn-primary">
              Get Started Free
            </a>
            <a href="/blog" class="btn-ghost">
              Read the Blog
            </a>
          </div>

          <div class="hero-card-wrapper hero-fade-in delay-2">
            <div class="hero-card">
              <div class="pulse-header">
                <span class="pulse-title">Training Pulse</span>
                <span class="trend-badge trend-up">+12% this week</span>
              </div>

              <div class="pulse-grid">
                <div class="pulse-stat">
                  <span class="pulse-value">47.3<span class="pulse-unit">km</span></span>
                  <span class="pulse-label">Distance</span>
                </div>
                <div class="pulse-stat">
                  <span class="pulse-value">4h 15m</span>
                  <span class="pulse-label">Duration</span>
                </div>
                <div class="pulse-stat">
                  <span class="pulse-value">5<span class="pulse-unit">runs</span></span>
                  <span class="pulse-label">Activities</span>
                </div>
                <div class="pulse-stat">
                  <span class="pulse-value">5:24<span class="pulse-unit">/km</span></span>
                  <span class="pulse-label">Avg Pace</span>
                </div>
              </div>

              <div class="pulse-calendar">
                <span class="card-label">This Week</span>
                <div class="bar-chart">
                  <div class="bar-col">
                    <div class="bar" style="height: 34%"></div>
                    <span class="bar-label">M</span>
                  </div>
                  <div class="bar-col">
                    <div class="bar bar-rest" style="height: 4%"></div>
                    <span class="bar-label">T</span>
                  </div>
                  <div class="bar-col">
                    <div class="bar" style="height: 56%"></div>
                    <span class="bar-label">W</span>
                  </div>
                  <div class="bar-col">
                    <div class="bar" style="height: 41%"></div>
                    <span class="bar-label">T</span>
                  </div>
                  <div class="bar-col">
                    <div class="bar bar-rest" style="height: 4%"></div>
                    <span class="bar-label">F</span>
                  </div>
                  <div class="bar-col">
                    <div class="bar" style="height: 79%"></div>
                    <span class="bar-label">S</span>
                  </div>
                  <div class="bar-col">
                    <div class="bar bar-active" style="height: 100%"></div>
                    <span class="bar-label">S</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- ACTIVITIES + RUNNING DYNAMICS                              -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section">
        <div class="container section-offset-left">
          <div class="offset-text scroll-fade-up">
            <h2 class="section-headline">Get to know every run.</h2>
            <p class="section-sub">Pace, heart rate, cadence — and all the details in between. Geek out on the numbers, or just get a friendly read on how you're doing.</p>
          </div>

          <div class="scroll-fade-right">
            <div class="demo-card">
              <div class="activity-header">
                <div>
                  <span class="activity-name">Morning Run</span>
                  <span class="activity-date">Today, 6:45 AM</span>
                </div>
                <span class="effort-badge effort-tempo">Tempo</span>
              </div>

              <div class="stat-grid-4">
                <div class="stat-pill">
                  <span class="stat-label">Distance</span>
                  <span class="stat-value">8.5 km</span>
                </div>
                <div class="stat-pill">
                  <span class="stat-label">Duration</span>
                  <span class="stat-value">42:15</span>
                </div>
                <div class="stat-pill">
                  <span class="stat-label">Avg Pace</span>
                  <span class="stat-value">4:58/km</span>
                </div>
                <div class="stat-pill">
                  <span class="stat-label">Elevation</span>
                  <span class="stat-value">85 m</span>
                </div>
              </div>

              <div class="hr-zones-wrapper">
                <span class="card-label">Heart Rate Zones</span>
                <div class="hr-zones-bar">
                  <div class="hr-zone" style="flex-basis: 8%; background: #3b82f6;" title="Z1 Recovery 8%"></div>
                  <div class="hr-zone" style="flex-basis: 22%; background: #22c55e;" title="Z2 Easy 22%"></div>
                  <div class="hr-zone" style="flex-basis: 45%; background: #f59e0b;" title="Z3 Aerobic 45%"></div>
                  <div class="hr-zone" style="flex-basis: 20%; background: #a855f7;" title="Z4 Threshold 20%"></div>
                  <div class="hr-zone" style="flex-basis: 5%; background: #ef4444;" title="Z5 Max 5%"></div>
                </div>
                <div class="hr-zone-labels">
                  <span>Z1</span><span>Z2</span><span>Z3</span><span>Z4</span><span>Z5</span>
                </div>
              </div>

              <div class="dynamics-section">
                <span class="card-label">Running Dynamics</span>
                <div class="stat-grid-4">
                  <div class="stat-pill">
                    <span class="stat-label">Cadence</span>
                    <span class="stat-value-sm">178 <span class="stat-unit">spm</span></span>
                  </div>
                  <div class="stat-pill">
                    <span class="stat-label">Vert. Osc.</span>
                    <span class="stat-value-sm">7.2 <span class="stat-unit">cm</span></span>
                  </div>
                  <div class="stat-pill">
                    <span class="stat-label">GCT</span>
                    <span class="stat-value-sm">238 <span class="stat-unit">ms</span></span>
                  </div>
                  <div class="stat-pill">
                    <span class="stat-label">Step Length</span>
                    <span class="stat-value-sm">1.18 <span class="stat-unit">m</span></span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- TRAINING BLOCKS -- FULL BLEED                              -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section section-blocks">
        <div class="container showcase-centered">
          <h2 class="section-headline centered scroll-fade-up">Training that fits your life.</h2>
          <p class="section-sub centered scroll-fade-up">Set a goal that matters to you — your first 5K, a half-marathon PB, whatever it is. Track your weekly miles and see how you're coming along.</p>

          <div class="scroll-expand">
            <div class="app-window">
              <div class="app-window-bar">
                <span class="window-dot"></span>
                <span class="window-dot"></span>
                <span class="window-dot"></span>
              </div>
              <div class="app-window-content">
                <div class="block-header">
                  <div>
                    <span class="activity-name">Marathon Prep</span>
                    <span class="activity-date">Nov 4 — Dec 29 &middot; 18 days left</span>
                  </div>
                </div>

                <div class="progress-row">
                  <div class="progress-track">
                    <div class="progress-fill" style="width: 68%"></div>
                  </div>
                  <span class="progress-text">68%</span>
                </div>

                <div class="block-body">
                  <div class="block-left">
                    <div class="stat-grid-4">
                      <div class="stat-pill">
                        <span class="stat-label">Distance</span>
                        <span class="stat-value">312 km</span>
                      </div>
                      <div class="stat-pill">
                        <span class="stat-label">Time</span>
                        <span class="stat-value">26h 45m</span>
                      </div>
                      <div class="stat-pill">
                        <span class="stat-label">Avg Pace</span>
                        <span class="stat-value">5:08/km</span>
                      </div>
                      <div class="stat-pill">
                        <span class="stat-label">Activities</span>
                        <span class="stat-value">42</span>
                      </div>
                    </div>

                    <div class="volume-section">
                      <span class="card-label">Weekly Volume</span>
                      <div class="volume-bars">
                        <div class="volume-col">
                          <div class="volume-bar" style="height: 73%"></div>
                          <span class="bar-label">W1</span>
                        </div>
                        <div class="volume-col">
                          <div class="volume-bar" style="height: 84%"></div>
                          <span class="bar-label">W2</span>
                        </div>
                        <div class="volume-col">
                          <div class="volume-bar" style="height: 94%"></div>
                          <span class="bar-label">W3</span>
                        </div>
                        <div class="volume-col">
                          <div class="volume-bar volume-deload" style="height: 55%"></div>
                          <span class="bar-label">W4</span>
                        </div>
                        <div class="volume-col">
                          <div class="volume-bar" style="height: 100%"></div>
                          <span class="bar-label">W5</span>
                        </div>
                        <div class="volume-col">
                          <div class="volume-bar volume-current" style="height: 76%"></div>
                          <span class="bar-label">W6</span>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="block-right">
                    <div class="goals-section">
                      <span class="card-label">Race Goals</span>
                      <div class="goal-list">
                        <div class="goal-item">
                          <span class="goal-label goal-a">A</span>
                          <span class="goal-target">3:15:00</span>
                          <span class="goal-pace">4:37/km</span>
                          <span class="status-pill status-behind">Behind</span>
                        </div>
                        <div class="goal-item">
                          <span class="goal-label goal-b">B</span>
                          <span class="goal-target">3:30:00</span>
                          <span class="goal-pace">4:58/km</span>
                          <span class="status-pill status-behind">Behind</span>
                        </div>
                        <div class="goal-item">
                          <span class="goal-label goal-c">C</span>
                          <span class="goal-target">3:45:00</span>
                          <span class="goal-pace">5:19/km</span>
                          <span class="status-pill status-ahead">Ahead</span>
                        </div>
                      </div>
                    </div>

                    <div class="te-section">
                      <span class="card-label">Training Effect</span>
                      <div class="te-row">
                        <div class="te-item">
                          <span class="te-value">3.4</span>
                          <span class="te-label">Aerobic</span>
                        </div>
                        <div class="te-item">
                          <span class="te-value">1.8</span>
                          <span class="te-label">Anaerobic</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- COMMAND BAR + CONTEXTUAL COACHES                           -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section">
        <div class="container showcase-centered">
          <h2 class="section-headline centered scroll-fade-up">A coach in your pocket.</h2>
          <p class="section-sub centered scroll-fade-up">Friendly AI helpers for any question — about a specific run, your training block, or just running in general. Hit <kbd class="cmdk-kbd-inline">&#8984;K</kbd> from anywhere and ask away.</p>

          <div class="cmdk-wrapper scroll-scale-in">
            <div class="demo-card cmdk-card showcase-card-sm">
              <div class="cmdk-input-row">
                <svg class="cmdk-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"></circle>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <span class="cmdk-input-text">Type a command...</span>
                <span class="cmdk-kbd">esc</span>
              </div>

              <div class="cmdk-divider"></div>

              <div class="cmdk-group">
                <span class="cmdk-group-label">This Activity</span>
                <div class="cmdk-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                  </svg>
                  <span>Review This Activity</span>
                </div>
                <div class="cmdk-item cmdk-item-active">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                  </svg>
                  <span>Ask Coach About This Run</span>
                </div>
                <div class="cmdk-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                  </svg>
                  <span>View Matched Runs</span>
                </div>
              </div>

              <div class="cmdk-divider"></div>

              <div class="cmdk-group">
                <span class="cmdk-group-label">Navigation</span>
                <div class="cmdk-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                  </svg>
                  <span>Home</span>
                </div>
                <div class="cmdk-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="2" y1="12" x2="22" y2="12"></line>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                  </svg>
                  <span>Passport</span>
                </div>
              </div>
            </div>

            <div class="coach-tooltip scroll-fade-up-delayed">
              <div class="tooltip-body">
                <div class="tooltip-avatar">AI</div>
                <div class="tooltip-text">
                  Great session! You held 4:45/km with a negative split in the last 2km. HR stayed in zone 4 — ideal for tempo work.
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- COMPARE + MATCHED RUNS                                     -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section">
        <div class="container section-offset-right">
          <div class="demo-card scroll-fade-left">
            <div class="compare-cards">
              <div class="compare-run scroll-fade-left">
                <div class="compare-run-header">
                  <span class="compare-dot" style="background:#3b82f6"></span>
                  <div>
                    <span class="activity-name">Tempo Run</span>
                    <span class="activity-date">Dec 15</span>
                  </div>
                </div>
                <div class="stat-grid-3">
                  <div class="stat-pill-sm">
                    <span class="stat-label">Distance</span>
                    <span class="stat-value-sm">10.2 km</span>
                  </div>
                  <div class="stat-pill-sm">
                    <span class="stat-label">Pace</span>
                    <span class="stat-value-sm">4:45/km</span>
                  </div>
                  <div class="stat-pill-sm">
                    <span class="stat-label">Avg HR</span>
                    <span class="stat-value-sm">165 bpm</span>
                  </div>
                </div>
              </div>
              <div class="compare-run scroll-fade-right">
                <div class="compare-run-header">
                  <span class="compare-dot" style="background:#a855f7"></span>
                  <div>
                    <span class="activity-name">Easy Run</span>
                    <span class="activity-date">Dec 12</span>
                  </div>
                </div>
                <div class="stat-grid-3">
                  <div class="stat-pill-sm">
                    <span class="stat-label">Distance</span>
                    <span class="stat-value-sm">8.1 km</span>
                  </div>
                  <div class="stat-pill-sm">
                    <span class="stat-label">Pace</span>
                    <span class="stat-value-sm">5:13/km</span>
                  </div>
                  <div class="stat-pill-sm">
                    <span class="stat-label">Avg HR</span>
                    <span class="stat-value-sm">142 bpm</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="compare-chart-wrapper scroll-fade-up">
              <span class="card-label">Pace Comparison (min/km)</span>
              <svg viewBox="0 0 200 100" class="compare-svg" preserveAspectRatio="none">
                <polyline class="line-draw-1"
                  points="0,38 28,33 57,28 85,23 114,15 142,28 171,33 200,38"
                  fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                />
                <polyline class="line-draw-2"
                  points="0,72 28,77 57,67 85,60 114,72 142,82 171,77 200,62"
                  fill="none" stroke="#a855f7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                />
              </svg>
            </div>

            <div class="compare-footer scroll-fade-up">
              <div class="compare-badges">
                <span class="insight-badge"><span class="insight-dot" style="background:#3b82f6"></span>Faster pace</span>
                <span class="insight-badge"><span class="insight-dot" style="background:#a855f7"></span>Lower HR</span>
                <span class="insight-badge"><span class="insight-dot" style="background:#22c55e"></span>Negative split</span>
              </div>
              <span class="matched-hint">&#8627; 3 matched runs on this route</span>
            </div>
          </div>

          <div class="offset-text scroll-fade-up">
            <h2 class="section-headline">See how far you've come.</h2>
            <p class="section-sub">Put two runs side by side — pace, heart rate, splits. We'll even match runs on the same route, so you can watch yourself get stronger.</p>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- DASHBOARDS + REPORTS — BENTO GRID                           -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section">
        <div class="container showcase-centered">
          <h2 class="section-headline centered scroll-fade-up">Your data, your way.</h2>
          <p class="section-sub centered scroll-fade-up">Build a dashboard that shows what matters to you. Plus a friendly weekly recap with anything worth noticing.</p>

          <div class="bento-grid scroll-scale-in">
            <div class="dashboard-card demo-card">
              <div class="dashboard-header">
                <span class="dashboard-title">Custom Dashboard</span>
                <span class="dashboard-badge">3 widgets</span>
              </div>
              <div class="dashboard-grid">
                <div class="widget-placeholder widget-line">
                  <span class="widget-label">Weekly Distance</span>
                  <svg viewBox="0 0 120 40" class="widget-chart" preserveAspectRatio="none">
                    <polyline points="0,35 20,28 40,30 60,18 80,22 100,12 120,8" fill="none" stroke="#3b82f6" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </div>
                <div class="widget-placeholder widget-bar">
                  <span class="widget-label">Monthly Pace</span>
                  <div class="widget-bars">
                    <div class="widget-bar-item" style="height: 60%"></div>
                    <div class="widget-bar-item" style="height: 75%"></div>
                    <div class="widget-bar-item" style="height: 85%"></div>
                    <div class="widget-bar-item" style="height: 70%"></div>
                    <div class="widget-bar-item widget-bar-current" style="height: 90%"></div>
                  </div>
                </div>
                <div class="widget-placeholder widget-stat">
                  <span class="widget-label">Streak</span>
                  <span class="widget-big-number">14<span class="widget-big-unit">days</span></span>
                </div>
              </div>
            </div>

            <div class="report-card demo-card">
              <div class="mini-card-header">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                </svg>
                <span class="mini-card-title">Weekly Report</span>
                <span class="report-status report-ready">Ready</span>
              </div>
              <span class="mini-card-date">Dec 9 — Dec 15</span>
              <div class="report-summary">
                <div class="report-metrics">
                  <div class="report-metric">
                    <span class="report-metric-label">Volume</span>
                    <span class="report-metric-value report-metric-up">+12%</span>
                  </div>
                  <div class="report-metric">
                    <span class="report-metric-label">Avg Pace</span>
                    <span class="report-metric-value report-metric-up">Improved</span>
                  </div>
                  <div class="report-metric">
                    <span class="report-metric-label">Recovery</span>
                    <span class="report-metric-value">On track</span>
                  </div>
                </div>
                <p class="report-insight">Recovery days well placed. Consider adding a hill session next week to build strength for your upcoming half marathon.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- PASSPORT                                                    -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section">
        <div class="container showcase-centered">
          <div class="passport-atmospheric demo-card scroll-fade-up">
            <div class="passport-overlay">
              <h2 class="passport-headline">Every run paints your map.</h2>
              <div class="passport-stats">
                <span class="passport-stat"><strong>12</strong> cities</span>
                <span class="passport-divider">&middot;</span>
                <span class="passport-stat"><strong>3</strong> countries</span>
              </div>
            </div>
            <div class="passport-map">
              <svg viewBox="0 0 600 320" class="passport-svg" preserveAspectRatio="xMidYMid meet">
                <!-- Topographic contour lines -->
                <path d="M0,200 Q60,180 120,195 T240,185 Q300,178 360,190 T480,182 Q540,175 600,188" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>

                  <line x1="24" y1="24" x2="24" y2="18" stroke="#3b82f6" stroke-width="1.5" stroke-linecap="round"/>
                  <line x1="24" y1="24" x2="28" y2="26" stroke="#3b82f6" stroke-width="1.5" stroke-linecap="round"/>
                  <circle cx="24" cy="24" r="1.5" fill="#3b82f6"/>
                </svg>
              </div>
              <span class="sync-node-title">Your Watch</span>
              <div class="sync-node-logos">
                <span class="sync-brand-pill">Garmin</span>
                <span class="sync-brand-pill">Suunto</span>
                <span class="sync-brand-pill">Coros</span>
                <span class="sync-brand-pill">Polar</span>
                <span class="sync-brand-pill">Wahoo</span>
              </div>
              <span class="sync-node-label">Record your run</span>
            </div>

            <!-- Connector 1 -->
            <div class="sync-connector">
              <div class="sync-connector-line"></div>
              <div class="sync-connector-dot sync-dot-blue"></div>
              <div class="sync-connector-dot sync-dot-blue"></div>
              <div class="sync-connector-dot sync-dot-blue"></div>
            </div>

            <!-- Node 2: Intervals.icu -->
            <div class="sync-node">
              <div class="sync-node-icon">
                <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="8" y="8" width="32" height="32" rx="6" stroke="#22c55e" stroke-width="2" fill="rgba(34,197,94,0.06)"/>
                  <rect x="14" y="26" width="4" height="8" rx="1" fill="#22c55e" opacity="0.5"/>
                  <rect x="20" y="20" width="4" height="14" rx="1" fill="#22c55e" opacity="0.7"/>
                  <rect x="26" y="16" width="4" height="18" rx="1" fill="#22c55e" opacity="0.85"/>
                  <rect x="32" y="22" width="4" height="12" rx="1" fill="#22c55e" opacity="0.6"/>
                  <polyline points="14,24 20,18 26,14 36,20" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                  <circle cx="36" cy="20" r="2" fill="#22c55e"/>
                </svg>
              </div>
              <span class="sync-node-title">Intervals.icu</span>
              <span class="sync-node-label">Syncs automatically</span>
            </div>

            <!-- Connector 2 -->
            <div class="sync-connector">
              <div class="sync-connector-line"></div>
              <div class="sync-connector-dot sync-dot-green"></div>
              <div class="sync-connector-dot sync-dot-green"></div>
              <div class="sync-connector-dot sync-dot-green"></div>
            </div>

            <!-- Node 3: TORC -->
            <div class="sync-node">
              <div class="sync-node-icon">
                <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="8" y="8" width="32" height="32" rx="6" stroke="#a855f7" stroke-width="2" fill="rgba(168,85,247,0.06)"/>
                  <path d="M20 16 L20 32" stroke="#a855f7" stroke-width="2.5" stroke-linecap="round"/>
                  <path d="M15 16 L25 16" stroke="#a855f7" stroke-width="2.5" stroke-linecap="round"/>
                  <circle cx="32" cy="18" r="4" stroke="#a855f7" stroke-width="1.5" fill="rgba(168,85,247,0.15)"/>
                  <path d="M30 24 Q28 28 30 32" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round" fill="none"/>
                  <path d="M34 24 Q36 28 34 32" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round" fill="none"/>
                </svg>
              </div>
              <span class="sync-node-title">TORC</span>
              <span class="sync-node-label">Insights ready</span>
            </div>
          </div>

          <p class="sync-footnote scroll-fade-up">+200 more devices supported via Intervals.icu</p>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- BLOG + TOOLS                                               -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section section-blog">
        <div class="container">
          <div class="section-header scroll-fade-up">
            <div>
              <h2 class="section-headline-sm">Have a read.</h2>
              <p class="section-sub-sm">Free tools, beginner-friendly guides, and a few tips for your next race.</p>
            </div>
            <div class="header-links">
              <a href="/blog" class="view-all">Blog &rarr;</a>
              <a href="/tools" class="view-all">Tools &rarr;</a>
            </div>
          </div>
          <div class="blog-grid">
            {
              posts.slice(0, 3).map((post, index) => (
                <article class={`blog-card scroll-fade-up stagger-${index + 1}`}>
                  <a href={`/blog/${post.id}/`}>
                    <div class="blog-img-wrap">
                      <Image
                        src={post.data.heroImage}
                        alt=""
                        width={800}
                        height={224}
                        class="blog-img"
                        format="webp"
                        quality={80}
                        loading={index < 2 ? "eager" : "lazy"}
                      />
                    </div>
                    <div class="blog-content">
                      {post.data.pubDate && (
                        <time
                          datetime={post.data.pubDate.toString()}
                          class="blog-date"
                        >
                          <FormattedDate date={post.data.pubDate} />
                        </time>
                      )}
                      <h3 class="blog-title">{post.data.title}</h3>
                      {post.data.description && (
                        <p class="blog-desc">{post.data.description}</p>
                      )}
                    </div>
                  </a>
                </article>
              ))
            }
          </div>
          <div class="tools-grid">
            <a href="/tools/pace-review/" class="tool-card scroll-fade-up stagger-1">
              <Image
                src={barca}
                alt="Race Day Ready tool"
                format="webp"
                quality={80}
                class="tool-img"
              />
              <div class="tool-overlay">
                <div class="tool-info">
                  <span class="tool-badge">Free Tool</span>
                  <h3 class="tool-title">Race Day Ready</h3>
                  <p class="tool-desc">Review your race pacing strategy</p>
                </div>
              </div>
            </a>
            <a href="/tools/pace-calculator" class="tool-card scroll-fade-up stagger-2">
              <Image
                src={timer}
                alt="Pace Calculator tool"
                format="webp"
                quality={80}
                class="tool-img"
              />
              <div class="tool-overlay">
                <div class="tool-info">
                  <span class="tool-badge">Free Tool</span>
                  <h3 class="tool-title">Pace Calculator</h3>
                  <p class="tool-desc">Calculate splits for any distance</p>
                </div>
              </div>
            </a>
            <a href="/tools/runshare/" class="tool-card scroll-fade-up stagger-3">
              <Image
                src={friends}
                alt="Social Card Builder tool"
                format="webp"
                quality={80}
                class="tool-img"
              />
              <div class="tool-overlay">
                <div class="tool-info">
                  <span class="tool-badge">Free Tool</span>
                  <h3 class="tool-title">Social Card Builder</h3>
                  <p class="tool-desc">Share your runs on social media</p>
                </div>
              </div>
            </a>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- FINAL CTA                                                  -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section section-cta section-tall">
        <div class="cta-glow"></div>
        <div class="container cta-content scroll-fade-up">
          <h2 class="cta-headline">
            <span class="cta-word cta-w1">Everyone</span>
            <span class="cta-word cta-w2">starts</span>
            <span class="cta-word cta-w3">somewhere.</span>
          </h2>
          <a href={`${TORC_APP_URL}/login`} class="btn-primary btn-lg btn-glow">
            Get Started Free
          </a>
        </div>
      </section>

    </main>

    <Footer />
  </body>
</html>

<style is:global>

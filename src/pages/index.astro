      <section class="section">
        <div class="container showcase-centered">
          <h2 class="section-headline centered scroll-fade-up">It just shows&nbsp;up.</h2>
          <p class="section-sub centered scroll-fade-up">Go for your run. By the time you're home, your data's already&nbsp;here&nbsp;&mdash; no uploads, no exports, no&nbsp;faff. We sync through Intervals.icu.</p>

          <div class="sync-pipeline scroll-scale-in">
            <!-- Node 1: Your Watch -->
            <div class="sync-node">
              <div class="sync-node-icon">
                <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="14" y="6" width="20" height="6" rx="2" fill="#3b82f6" opacity="0.3"/>
                  <rect x="14" y="36" width="20" height="6" rx="2" fill="#3b82f6" opacity="0.3"/>

---
export const prerender = true;
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION, TORC_APP_URL } from "../consts";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import FormattedDate from "@/components/FormattedDate.astro";
import barca from "../images/torc.webp";
import timer from "../images/timer.webp";
import friends from "../images/friends.webp";

const posts = (await getCollection("blog")).sort(
  (a, b) => (b.data.pubDate || 0).valueOf() - (a.data.pubDate || 0).valueOf()
);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="landing-body">
    <Header />

    <main class="landing-main">

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- HERO                                                       -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="hero">
        <div class="hero-glow"></div>
        <div class="container hero-grid">
          <div class="hero-text">
            <h1 class="hero-headline hero-fade-in">
              Train smarter.<br />Run faster.
            </h1>
            <p class="hero-sub hero-fade-in delay-1">
              AI-powered coaching and insights that turn your running data into
              faster times and smarter training.
            </p>
            <div class="hero-ctas hero-fade-in delay-2">
              <a href={`${TORC_APP_URL}/login`} class="btn-primary">
                Get Started Free
              </a>
              <a href="/blog" class="btn-ghost">
                Read the Blog
              </a>
            </div>
          </div>

          <!-- Dashboard Card -->
          <div class="hero-card-wrapper hero-fade-in delay-3">
            <div class="hero-card float">
              <div class="card-header">
                <span class="card-label">This Week</span>
                <span class="trend-badge trend-up">+12%</span>
              </div>

              <div class="metric-row">
                <div class="metric">
                  <span class="metric-label">Distance</span>
                  <span class="metric-value">47.3 km</span>
                </div>
                <div class="metric">
                  <span class="metric-label">Duration</span>
                  <span class="metric-value">4h 15m</span>
                </div>
                <div class="metric">
                  <span class="metric-label">Activities</span>
                  <span class="metric-value">5 runs</span>
                </div>
              </div>

              <div class="bar-chart">
                <div class="bar-col">
                  <div class="bar" style="height: 34%"></div>
                  <span class="bar-label">M</span>
                </div>
                <div class="bar-col">
                  <div class="bar" style="height: 0%"></div>
                  <span class="bar-label">T</span>
                </div>
                <div class="bar-col">
                  <div class="bar" style="height: 56%"></div>
                  <span class="bar-label">W</span>
                </div>
                <div class="bar-col">
                  <div class="bar" style="height: 41%"></div>
                  <span class="bar-label">T</span>
                </div>
                <div class="bar-col">
                  <div class="bar" style="height: 0%"></div>
                  <span class="bar-label">F</span>
                </div>
                <div class="bar-col">
                  <div class="bar" style="height: 79%"></div>
                  <span class="bar-label">S</span>
                </div>
                <div class="bar-col">
                  <div class="bar" style="height: 100%"></div>
                  <span class="bar-label">S</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- FEATURE: ACTIVITIES                                        -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section">
        <div class="container feature-grid">
          <div class="feature-text scroll-fade-up">
            <span class="section-label">Activities</span>
            <h2 class="section-headline">Every run. Every metric.</h2>
            <p class="section-sub">
              Track distance, pace, heart rate zones, elevation, and more.
              See your weekly trends at a glance.
            </p>
          </div>

          <div class="scroll-fade-up stagger-2">
            <div class="demo-card">
              <div class="activity-header">
                <div>
                  <span class="activity-name">Morning Run</span>
                  <span class="activity-date">Today, 6:45 AM</span>
                </div>
                <span class="effort-badge effort-tempo">Tempo</span>
              </div>

              <div class="stat-grid-4">
                <div class="stat-pill">
                  <span class="stat-label">Distance</span>
                  <span class="stat-value">8.5 km</span>
                </div>
                <div class="stat-pill">
                  <span class="stat-label">Duration</span>
                  <span class="stat-value">42:15</span>
                </div>
                <div class="stat-pill">
                  <span class="stat-label">Avg HR</span>
                  <span class="stat-value">152 bpm</span>
                </div>
                <div class="stat-pill">
                  <span class="stat-label">Elevation</span>
                  <span class="stat-value">85 m</span>
                </div>
              </div>

              <div class="hr-zones-wrapper">
                <span class="card-label">Heart Rate Zones</span>
                <div class="hr-zones-bar">
                  <div class="hr-zone" style="flex-basis: 8%; background: #3b82f6;" title="Z1 Recovery 8%"></div>
                  <div class="hr-zone" style="flex-basis: 22%; background: #22c55e;" title="Z2 Easy 22%"></div>
                  <div class="hr-zone" style="flex-basis: 45%; background: #f59e0b;" title="Z3 Aerobic 45%"></div>
                  <div class="hr-zone" style="flex-basis: 20%; background: #a855f7;" title="Z4 Threshold 20%"></div>
                  <div class="hr-zone" style="flex-basis: 5%; background: #ef4444;" title="Z5 Max 5%"></div>
                </div>
                <div class="hr-zone-labels">
                  <span>Z1</span><span>Z2</span><span>Z3</span><span>Z4</span><span>Z5</span>
                </div>
              </div>

              <div class="sparkline-wrapper">
                <span class="card-label">Weekly Trend</span>
                <svg viewBox="0 0 200 60" class="sparkline-svg" preserveAspectRatio="none">
                  <polyline
                    points="0,42 33,60 66,12 99,28 132,60 165,4 200,0"
                    fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                  />
                  <polyline
                    points="0,46 33,22 66,60 99,34 132,16 165,8 200,6"
                    fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" stroke-dasharray="4 3" stroke-linecap="round" stroke-linejoin="round"
                  />
                </svg>
                <div class="sparkline-legend">
                  <span class="legend-item"><span class="legend-dot" style="background:#3b82f6"></span>This week</span>
                  <span class="legend-item"><span class="legend-dot" style="background:rgba(255,255,255,0.25)"></span>Last week</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- FEATURE: BLOCKS                                            -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section">
        <div class="container feature-grid feature-grid-reverse">
          <div class="feature-text scroll-fade-right">
            <span class="section-label">Training Blocks</span>
            <h2 class="section-headline">Structure your training.</h2>
            <p class="section-sub">
              Organize runs into training blocks. Set goals, track volume,
              and see your progression week over week.
            </p>
          </div>

          <div class="scroll-fade-left">
            <div class="demo-card">
              <div class="card-header">
                <div>
                  <span class="activity-name">Marathon Prep</span>
                  <span class="activity-date">Nov 4 — Dec 29 &middot; 18 days left</span>
                </div>
              </div>

              <div class="progress-row">
                <div class="progress-track">
                  <div class="progress-fill" style="width: 68%"></div>
                </div>
                <span class="progress-text">68%</span>
              </div>

              <div class="stat-grid-4">
                <div class="stat-pill">
                  <span class="stat-label">Distance</span>
                  <span class="stat-value">312 km</span>
                </div>
                <div class="stat-pill">
                  <span class="stat-label">Time</span>
                  <span class="stat-value">26h 45m</span>
                </div>
                <div class="stat-pill">
                  <span class="stat-label">Avg Pace</span>
                  <span class="stat-value">5:08/km</span>
                </div>
                <div class="stat-pill">
                  <span class="stat-label">Activities</span>
                  <span class="stat-value">42</span>
                </div>
              </div>

              <div class="volume-section">
                <span class="card-label">Weekly Volume</span>
                <div class="volume-bars">
                  <div class="volume-col">
                    <div class="volume-bar" style="height: 73%"></div>
                    <span class="bar-label">W1</span>
                  </div>
                  <div class="volume-col">
                    <div class="volume-bar" style="height: 84%"></div>
                    <span class="bar-label">W2</span>
                  </div>
                  <div class="volume-col">
                    <div class="volume-bar" style="height: 94%"></div>
                    <span class="bar-label">W3</span>
                  </div>
                  <div class="volume-col">
                    <div class="volume-bar" style="height: 77%"></div>
                    <span class="bar-label">W4</span>
                  </div>
                  <div class="volume-col">
                    <div class="volume-bar" style="height: 100%"></div>
                    <span class="bar-label">W5</span>
                  </div>
                  <div class="volume-col">
                    <div class="volume-bar" style="height: 76%"></div>
                    <span class="bar-label">W6</span>
                  </div>
                </div>
              </div>

              <div class="goals-section">
                <span class="card-label">Race Goals</span>
                <div class="goal-list">
                  <div class="goal-item">
                    <span class="goal-label goal-a">A</span>
                    <span class="goal-target">3:15:00</span>
                    <span class="goal-pace">4:37/km</span>
                    <span class="status-pill status-behind">Behind</span>
                  </div>
                  <div class="goal-item">
                    <span class="goal-label goal-b">B</span>
                    <span class="goal-target">3:30:00</span>
                    <span class="goal-pace">4:58/km</span>
                    <span class="status-pill status-behind">Behind</span>
                  </div>
                  <div class="goal-item">
                    <span class="goal-label goal-c">C</span>
                    <span class="goal-target">3:45:00</span>
                    <span class="goal-pace">5:19/km</span>
                    <span class="status-pill status-ahead">Ahead</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- FEATURE: COMPARE                                           -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section">
        <div class="container feature-grid">
          <div class="feature-text scroll-fade-up">
            <span class="section-label">Compare</span>
            <h2 class="section-headline">Stack your runs.</h2>
            <p class="section-sub">
              Compare multiple activities side by side. Spot patterns,
              find your fastest routes, and track improvement.
            </p>
          </div>

          <div class="scroll-scale-in">
            <div class="demo-card">
              <div class="compare-cards">
                <div class="compare-run">
                  <div class="compare-run-header">
                    <span class="compare-dot" style="background:#3b82f6"></span>
                    <div>
                      <span class="activity-name">Tempo Run</span>
                      <span class="activity-date">Dec 15</span>
                    </div>
                  </div>
                  <div class="stat-grid-3">
                    <div class="stat-pill-sm">
                      <span class="stat-label">Distance</span>
                      <span class="stat-value-sm">10.2 km</span>
                    </div>
                    <div class="stat-pill-sm">
                      <span class="stat-label">Pace</span>
                      <span class="stat-value-sm">4:45/km</span>
                    </div>
                    <div class="stat-pill-sm">
                      <span class="stat-label">Avg HR</span>
                      <span class="stat-value-sm">165 bpm</span>
                    </div>
                  </div>
                </div>
                <div class="compare-run">
                  <div class="compare-run-header">
                    <span class="compare-dot" style="background:#a855f7"></span>
                    <div>
                      <span class="activity-name">Easy Run</span>
                      <span class="activity-date">Dec 12</span>
                    </div>
                  </div>
                  <div class="stat-grid-3">
                    <div class="stat-pill-sm">
                      <span class="stat-label">Distance</span>
                      <span class="stat-value-sm">8.1 km</span>
                    </div>
                    <div class="stat-pill-sm">
                      <span class="stat-label">Pace</span>
                      <span class="stat-value-sm">5:13/km</span>
                    </div>
                    <div class="stat-pill-sm">
                      <span class="stat-label">Avg HR</span>
                      <span class="stat-value-sm">142 bpm</span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="compare-chart-wrapper">
                <span class="card-label">Pace Comparison (min/km)</span>
                <svg viewBox="0 0 200 80" class="compare-svg" preserveAspectRatio="none">
                  <polyline
                    points="0,30 28,26 57,22 85,18 114,12 142,22 171,26 200,30"
                    fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                  />
                  <polyline
                    points="0,58 28,62 57,54 85,48 114,58 142,66 171,62 200,50"
                    fill="none" stroke="#a855f7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                  />
                </svg>
              </div>

              <div class="compare-badges">
                <span class="insight-badge"><span class="insight-dot" style="background:#3b82f6"></span>Faster pace</span>
                <span class="insight-badge"><span class="insight-dot" style="background:#a855f7"></span>Lower HR</span>
                <span class="insight-badge"><span class="insight-dot" style="background:#22c55e"></span>Negative split</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- FEATURE: COACH                                             -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section">
        <div class="container feature-grid feature-grid-reverse">
          <div class="feature-text scroll-fade-right">
            <span class="section-label">AI Coach</span>
            <h2 class="section-headline">AI that knows your training.</h2>
            <p class="section-sub">
              Get AI coaching and personalized insights on every run.
              Ask questions, get answers grounded in your data.
            </p>
          </div>

          <div class="scroll-fade-left">
            <div class="demo-card coach-card">
              <div class="chat-messages">
                <div class="chat-msg chat-user">
                  <div class="chat-bubble chat-bubble-user">
                    How was my tempo run today?
                  </div>
                </div>
                <div class="chat-msg chat-ai">
                  <div class="chat-avatar">AI</div>
                  <div class="chat-bubble chat-bubble-ai">
                    Great session! You held 4:45/km consistently with a negative
                    split in the last 2km. Your HR stayed in zone 4 which is
                    ideal for tempo work. Consider extending to 12km next week.
                  </div>
                </div>
              </div>
              <div class="chat-input-mock">
                <span class="chat-placeholder">Ask about your training...</span>
                <span class="chat-send-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                </span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- FEATURE: COMMAND BAR                                        -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section">
        <div class="container feature-grid">
          <div class="feature-text scroll-fade-up">
            <span class="section-label">Command Bar</span>
            <h2 class="section-headline">Do anything. Instantly.</h2>
            <p class="section-sub">
              Hit <kbd class="cmdk-kbd-inline">&#8984;K</kbd> from anywhere. Navigate, take actions, and get context-aware
              suggestions based on exactly where you are.
            </p>
          </div>

          <div class="scroll-scale-in">
            <div class="demo-card cmdk-card">
              <div class="cmdk-input-row">
                <svg class="cmdk-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"></circle>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <span class="cmdk-input-text">Type a command...</span>
                <span class="cmdk-kbd">esc</span>
              </div>

              <div class="cmdk-divider"></div>

              <div class="cmdk-group">
                <span class="cmdk-group-label">This Activity</span>
                <div class="cmdk-item cmdk-item-active">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                  </svg>
                  <span>Review This Activity</span>
                </div>
                <div class="cmdk-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7"></rect>
                    <rect x="14" y="3" width="7" height="7"></rect>
                    <rect x="3" y="14" width="7" height="7"></rect>
                    <rect x="14" y="14" width="7" height="7"></rect>
                  </svg>
                  <span>View Laps</span>
                </div>
                <div class="cmdk-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                  </svg>
                  <span>Ask Coach About This Run</span>
                </div>
              </div>

              <div class="cmdk-divider"></div>

              <div class="cmdk-group">
                <span class="cmdk-group-label">Navigation</span>
                <div class="cmdk-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                  </svg>
                  <span>Home</span>
                </div>
                <div class="cmdk-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                  </svg>
                  <span>Activities</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- BLOG PREVIEW                                               -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section section-blog">
        <div class="container">
          <div class="section-header scroll-fade-up">
            <h2 class="section-headline-sm">From the Blog</h2>
            <a href="/blog" class="view-all">View all &rarr;</a>
          </div>
          <div class="blog-grid">
            {
              posts.slice(0, 3).map((post, index) => (
                <article class={`blog-card scroll-fade-up stagger-${index + 1}`}>
                  <a href={`/blog/${post.id}/`}>
                    <div class="blog-img-wrap">
                      <Image
                        src={post.data.heroImage}
                        alt=""
                        width={800}
                        height={224}
                        class="blog-img"
                        format="webp"
                        quality={80}
                        loading={index < 2 ? "eager" : "lazy"}
                      />
                    </div>
                    <div class="blog-content">
                      {post.data.pubDate && (
                        <time
                          datetime={post.data.pubDate.toString()}
                          class="blog-date"
                        >
                          <FormattedDate date={post.data.pubDate} />
                        </time>
                      )}
                      <h3 class="blog-title">{post.data.title}</h3>
                      {post.data.description && (
                        <p class="blog-desc">{post.data.description}</p>
                      )}
                    </div>
                  </a>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- FREE TOOLS                                                 -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section">
        <div class="container">
          <div class="section-header scroll-fade-up">
            <h2 class="section-headline-sm">Free Running Tools</h2>
            <a href="/tools" class="view-all">View all &rarr;</a>
          </div>
          <div class="tools-grid">
            <a href="/tools/pace-review/" class="tool-card scroll-scale-in stagger-1">
              <Image
                src={barca}
                alt="Race Day Ready tool"
                format="webp"
                quality={80}
                class="tool-img"
              />
              <div class="tool-overlay">
                <div class="tool-info">
                  <h3 class="tool-title">Race Day Ready</h3>
                  <p class="tool-desc">Review your race pacing strategy</p>
                </div>
              </div>
            </a>
            <a href="/tools/pace-calculator" class="tool-card scroll-scale-in stagger-2">
              <Image
                src={timer}
                alt="Pace Calculator tool"
                format="webp"
                quality={80}
                class="tool-img"
              />
              <div class="tool-overlay">
                <div class="tool-info">
                  <h3 class="tool-title">Pace Calculator</h3>
                  <p class="tool-desc">Calculate splits for any distance</p>
                </div>
              </div>
            </a>
            <a href="/tools/runshare/" class="tool-card scroll-scale-in stagger-3">
              <Image
                src={friends}
                alt="Social Card Builder tool"
                format="webp"
                quality={80}
                class="tool-img"
              />
              <div class="tool-overlay">
                <div class="tool-info">
                  <h3 class="tool-title">Social Card Builder</h3>
                  <p class="tool-desc">Share your runs on social media</p>
                </div>
              </div>
            </a>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!-- FINAL CTA                                                  -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <section class="section section-cta">
        <div class="cta-glow"></div>
        <div class="container cta-content scroll-fade-up">
          <h2 class="cta-headline">Ready to run faster?</h2>
          <p class="cta-sub">
            Join runners using AI-powered insights to train smarter.
          </p>
          <a href={`${TORC_APP_URL}/login`} class="btn-primary btn-lg">
            Get Started Free
          </a>
        </div>
      </section>

    </main>

    <Footer />
  </body>
</html>

<style is:global>

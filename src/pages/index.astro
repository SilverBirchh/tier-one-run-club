  /* ──────────────────────────────────────────────────────────────── */

  .section-offset-left,
  .section-offset-right {
    display: grid;
    align-items: center;
    gap: 48px;
  }

  .section-offset-left {
    grid-template-columns: 1fr;
  }

  .section-offset-right {
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .section-offset-left {
      grid-template-columns: 0.38fr 0.62fr;
